@pytest.mark.asyncio
async def test_create_new_user(async_client: AsyncClient) -> None:
    """
    Test the creation of a new user.

    This test checks that a new user can be successfully created,
    and that the response contains the correct user data.
    """
    new_user = {
        "email": "newuser@example.com",
        "cpf": "12345678911",
        "password": "securepassword",
        "name": "New User",
        "active": True
    }

    response = await async_client.post("/users/", json=new_user)
    
    assert response.status_code == status.HTTP_201_CREATED

    body = response.json()
    assert body["email"] == new_user["email"]
    assert body["name"] == new_user["name"]
    assert body["active"] == new_user["active"]

    # Optional: Validate that the user ID is a valid UUID
    assert "id" in body
    assert len(body["id"]) == 36
